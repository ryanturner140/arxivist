    "abstract_excerpt": "Barrier derivatives depend on extrema and first-passage events and are therefore highly sensitive to volatility dynamics—especially to the instantaneous return–volatility correlation ρ, often called 'leverage'. We study a class of continuous-path stochastic-clock volatility models and develop a systematic small-ρ expansion around the ρ=0 backbone.",
    "key_claims": [
      "Transform-only pricing formulas for single- and double-barrier contracts under independent stochastic clocks (ρ=0)",
      "Systematic small-ρ leverage expansion around ρ=0 yielding a forced PDE hierarchy",
      "Padé resummation extends accuracy to equity-like correlations (|ρ|≈0.7–0.9) with errors below 0.3%",
      "Calibration workflow: vanilla fit → barrier backbone → leverage ρ scan with cached coefficients",
      "Transform-only framework is orders of magnitude faster than Monte Carlo (0.12s vs 20–35min)"
    ]
  },

  "architecture": {
    "confidence": 0.93,
    "description": "Mathematical pricing library, NOT a neural network. Composed of independent computational modules.",
    "components": [
      {
        "name": "ClockLaplaceTransform",
        "role": "Computes Phi_T(lambda) = E[exp(-lambda * Gamma_T)] for various clock families",
        "inputs": ["lambda (scalar or array)", "clock_params (dict)", "T (maturity)"],
        "outputs": ["Phi_T values on real grid"],
        "sub_families": ["IntegratedCIR", "SquaredOU", "MarkovSwitching", "AffineJump"]
      },
      {
        "name": "SingleBarrierPricer",
        "role": "Price UOP and DOC via single real integral (Theorems 2.1, 2.2)",
        "inputs": ["F0", "K", "H_or_L", "T", "r", "q", "Phi_T_callable"],
        "outputs": ["option_price (float)"],
        "key_formulas": ["Eq 2.33 (UOP)", "Eq 2.40 (DOC)"]
      },
      {
        "name": "DoubleBarrierPricer",
        "role": "Price DKO call via Dirichlet sine series (Theorem 3.1)",
        "inputs": ["F0", "K", "L", "H", "T", "r", "q", "Phi_T_callable", "N_terms"],
        "outputs": ["dko_price (float)"],
        "key_formulas": ["Eq 3.9"]
      },
      {
        "name": "LeverageExpansion",
        "role": "Compute rho-expansion coefficients u0, u1, ..., uN via Duhamel Monte Carlo",
        "inputs": ["rho", "barrier_type", "clock_model", "baseline_pricer", "N_order", "n_paths"],
        "outputs": ["coefficients list [C0...CN]", "approximated_price"]
      },
      {
        "name": "PadeAccelerator",
        "role": "Resum Taylor series into [L/M] Pade approximant, check poles",
        "inputs": ["coefficients list", "rho", "L", "M"],
        "outputs": ["pade_price", "pole_distance", "is_safe"]
      },
      {
        "name": "MonteCarloPricer",
        "role": "Reference MC pricer under correlated CIR/OU dynamics with bridge correction",
        "inputs": ["rho", "clock_params", "contract_params", "n_paths", "n_steps"],
        "outputs": ["mc_price", "mc_stderr"]
      },
      {
        "name": "CalibrationEngine",
        "role": "4-stage calibration: vanilla fit → barrier backbone → leverage scan → joint refine",
        "inputs": ["vanilla_surface", "barrier_quotes", "clock_family"],
        "outputs": ["calibrated_params (dict)"]
      }
    ]
  },

  "mathematical_spec": {
    "confidence": 0.97,
    "equations": [
      {
        "id": "log_price_dynamics",
        "latex": "X_t = x_0 + \\beta \\Gamma_t + B_{\\Gamma_t}, \\quad \\beta := -\\frac{1}{2}",
        "role": "Core time-change representation of log-forward price",
        "section": "2.1, Eq 2.9",
        "symbols": {"X_t": "log-forward price", "beta": "-1/2 (Ito drift)", "Gamma_t": "integrated variance (stochastic clock)", "B": "Brownian motion independent of clock"}
      },
      {
        "id": "clock_laplace_transform",
        "latex": "\\Phi_T(\\lambda) := E^{Q^T}[e^{-\\lambda \\Gamma_T}], \\quad \\lambda \\geq 0",
        "role": "Core pricing primitive — all model dependence enters via this transform",
        "section": "1.1, Eq 1.2 / 2.1 Eq 2.10"
      },
      {
        "id": "killed_density_prop2_1",
        "latex": "j^{(h)}_\\beta(x) = \\frac{2}{\\pi} e^{\\beta(x-x_0)} \\int_0^\\infty \\sin(u(h-x_0))\\sin(u(h-x)) \\Phi_T\\!\\left(\\frac{u^2+\\beta^2}{2}\\right) du",
        "role": "Killed terminal density under upper barrier h",
        "section": "Proposition 2.1, Eq 2.20"
      },
      {
        "id": "joint_survival_cdf_prop2_2",
        "latex": "J_\\beta(x;h) = \\frac{2}{\\pi} e^{\\beta(x-x_0)} \\int_0^\\infty \\sin(u(h-x_0)) \\frac{u\\cos(u(h-x)) - \\beta\\sin(u(h-x))}{u^2+\\beta^2} \\Phi_T\\!\\left(\\frac{u^2+\\beta^2}{2}\\right) du",
        "role": "Joint survival CDF: P(X_T <= x, M_T < h)",
        "section": "Proposition 2.2, Eq 2.30"
      },
      {
        "id": "uop_formula",
        "latex": "UOP_0 = P(0,T)\\frac{2}{\\pi}\\sqrt{KF_0} \\int_0^\\infty \\frac{\\sin(u(h-x_0))\\sin(u(h-k))}{u^2 + \\frac{1}{4}} \\Phi_T\\!\\left(\\frac{u^2+\\frac{1}{4}}{2}\\right) du",
        "role": "Up-and-out put price as single real integral",
        "section": "Theorem 2.1, Eq 2.33",
        "parameters": {"H": "upper barrier", "K": "strike", "h=log(H)": "log barrier", "k=log(K)": "log strike"}
      },
      {
        "id": "doc_formula",
        "latex": "DOC_0 = P(0,T)\\frac{2}{\\pi}\\sqrt{KF_0} \\int_0^\\infty \\frac{\\sin(u(x_0-l))\\sin(u(k-l))}{u^2 + \\frac{1}{4}} \\Phi_T\\!\\left(\\frac{u^2+\\frac{1}{4}}{2}\\right) du",
        "role": "Down-and-out call price as single real integral",
        "section": "Theorem 2.2, Eq 2.40",
        "parameters": {"L": "lower barrier", "l=log(L)": "log lower barrier"}
      },
      {
        "id": "dko_series",
        "latex": "DKO_0 = P(0,T)\\frac{2}{a} e^{-\\beta x_0} \\sum_{n=1}^\\infty \\sin(\\omega_n(x_0-l)) A_n \\Phi_T(\\lambda_n)",
        "role": "Double knock-out call price as Dirichlet sine series",
        "section": "Theorem 3.1, Eq 3.9",
        "parameters": {
          "omega_n": "n*pi/a, Dirichlet eigenfrequencies",
          "a": "h - l, corridor width",
          "lambda_n": "(omega_n^2 + beta^2)/2",
          "A_n": "payoff projection coefficients (Eq 3.5-3.7)"
        }
      },
      {
        "id": "payoff_coeff_An",
        "latex": "A_n = [F_{\\beta+1,n}(x)]_{x=c}^{x=h} - K[F_{\\beta,n}(x)]_{x=c}^{x=h}, \\quad F_{\\alpha,n}(x) = \\frac{e^{\\alpha x}}{\\alpha^2+\\omega_n^2}(\\alpha\\sin(\\omega_n(x-l)) - \\omega_n\\cos(\\omega_n(x-l)))",
        "role": "Explicit payoff projection coefficients for DKO series",
        "section": "Eq 3.5-3.8"
      },
      {
        "id": "cir_clock_transform",
        "latex": "\\Phi_T(\\lambda) = \\exp(-A(T;\\lambda) - B(T;\\lambda)v_0)",
        "role": "Laplace transform for integrated CIR variance",
        "section": "Section 4.1, Eq 4.2",
        "riccati": "dB/dt = kappa*B + lambda - (xi^2/2)*B^2, dA/dt = kappa*theta*B"
      },
      {
        "id": "sq_ou_clock_transform",
        "latex": "\\Phi_T(\\lambda) = \\exp(-A(T;\\lambda) - B(T;\\lambda)Y_0^2)",
        "role": "Laplace transform for squared OU variance",
        "section": "Section 4.2, Eq 4.9",
        "riccati": "dB/dt = 2*sigma^2*B^2 - 2*alpha*B + lambda, dA/dt = sigma^2*B"
      },
      {
        "id": "generator_splitting",
        "latex": "\\mathcal{L}_\\rho = \\mathcal{L}_0 + \\rho \\mathcal{L}_1, \\quad \\mathcal{L}_1 f = a(y)\\sqrt{v(y)} f_{xy}",
