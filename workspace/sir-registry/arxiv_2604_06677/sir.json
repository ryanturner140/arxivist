      },
      {
        "id": "duhamel_representation",
        "latex": "u_n(t,x,y) = -E^{Q^T}_{t,x,y}\\left[\\int_t^T (\\mathcal{L}_1 u_{n-1})(s, X_s^{(0)}, Y_s^{(0)}) 1_{\\{\\tau^{(0)}>s\\}} ds \\right]",
        "role": "Stochastic (Duhamel) representation of n-th correction coefficient",
        "section": "Proposition 5.1, Eq 5.17"
      },
      {
        "id": "pade_11",
        "latex": "u^\\rho \\approx \\mathcal{P}_{[1/1]}(\\rho) = \\frac{u_0 + \\rho(u_1 - u_0 u_2/u_1)}{1 - \\rho u_2/u_1}",
        "role": "[1/1] Padé approximant from first 3 coefficients",
        "section": "Section 5.8, Eq 5.22"
      },
      {
        "id": "characteristic_function",
        "latex": "\\phi_{X_T}(u) = e^{iux_0} \\Phi_T\\!\\left(\\frac{1}{2}u^2 - i\\beta u\\right)",
        "role": "Characteristic function for vanilla pricing via FFT/COS",
        "section": "Section 7.2, Eq 7.2"
      }
    ]
